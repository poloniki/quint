# --- API (runtime) ---
# OpenAI key used by the summarization step
OPENAI_API_KEY=sk-your-key-here
# Optional: your GPU model. Only "A100" enables bfloat16 on the JAX backend;
# any other value (or unset) uses float16. Pass at run time: docker run -e GPU_TYPE=A100 ...
# GPU_TYPE=A100

# --- Deployment helper (notebooks/Deploy_gpu_instance.ipynb) ---
# Email used to label / generate your SSH key
EMAIL=example@example.com
# Public IP or hostname of the GPU instance you provisioned (any cloud)
HOST=203.0.113.10
# SSH login user for the instance image. Often "root" on bare-VM providers, but
# "ubuntu" on AWS Ubuntu AMIs, your username on GCP, "azureuser" on Azure, etc.
SSH_USER=root
